# Database configuration (PostgreSQL)
DATABASE_URL=postgresql://postgres:YourNewPassword@localhost:5432/rejectioniq

# JWT Auth Security Key
SECRET_KEY=super_secret_key_change_in_production

# Gmail SMTP Configuration for Real OTP Delivery
# Set these to send real verification emails to users during registration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-16-character-gmail-app-password
SMTP_FROM=your-email@gmail.com
